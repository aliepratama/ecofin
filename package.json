{
  "name": "ecofin",
  "scripts": {
    "dev:spotlight": "bunx @spotlightjs/spotlight",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "build-stats": "cross-env ANALYZE=true bun run build",
    "clean": "rimraf .next out coverage",
    "lint": "ultracite check --type-aware --type-check",
    "lint:fix": "ultracite fix --type-aware --type-check",
    "check:types": "tsc --noEmit --pretty",
    "check:deps": "knip",
    "commit": "commit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "dotenv -c -- bunx drizzle-kit migrate",
    "db:studio": "bunx drizzle-kit studio",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@google-cloud/vertexai": "^1.12.0",
    "@hookform/resolvers": "^5.2.2",
    "@langchain/core": "^1.1.39",
    "@logtape/logtape": "^2.0.4",
    "@sentry/nextjs": "^10.45.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.102.1",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@types/qrcode": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^1.8.0",
    "next": "^16.2.1",
    "next-themes": "^1.0.0-beta.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.8.1",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/playwright": "^0.12.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@faker-js/faker": "^10.3.0",
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@spotlightjs/spotlight": "^4.11.3",
    "@swc/helpers": "^0.5.19",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "ultracite": "^7.3.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0",
    "vitest-browser-react": "^2.1.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "ultracite fix --type-aware --type-check"
    ]
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/github"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  }
}
